      "parameters": {
        "jsCode": "const blockResult = $input.first().json;\nconst requestData = $('Receive Enforcement Request').first().json.body || $('Receive Enforcement Request').first().json;\nconst isAutoAction = (requestData.action === 'auto_escalate');\n\nreturn [{\n  json: {\n    success: blockResult.success,\n    src_ip: requestData.src_ip,\n    block_duration_hours: requestData.block_duration_hours || 2,\n    risk_level: requestData.risk_level,\n    threat_type: requestData.threat_type,\n    mitre: requestData.mitre,\n    anomaly_score: requestData.anomaly_score,\n    analysis_summary: requestData.analysis_summary || '',\n    timestamp_aest: requestData.timestamp_aest || new Date().toISOString(),\n    triggered_by: isAutoAction ? 'auto_escalation' : 'admin_approval',\n    reason: requestData.reason || 'Admin approved',\n    is_auto_action: isAutoAction\n  }\n}];"
      },
