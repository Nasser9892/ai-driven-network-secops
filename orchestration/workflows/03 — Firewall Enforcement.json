        "jsonBody": "={\n  \"src_ip\": \"{{ $('Parse Result').first().json.src_ip }}\",\n  \"subject\": \"SecOps Escalation — {{ $('Parse Result').first().json.risk_level }} — {{ $('Parse Result').first().json.src_ip }}\",\n  \"body\": \"Automated escalation. IP {{ $('Parse Result').first().json.src_ip }} was auto-blocked. Threat: {{ $('Parse Result').first().json.threat_type }} | MITRE: {{ $('Parse Result').first().json.mitre }} | Risk: {{ $('Parse Result').first().json.risk_level }}\",\n  \"risk_level\": \"{{ $('Parse Result').first().json.risk_level }}\",\n  \"threat_type\": \"{{ $('Parse Result').first().json.threat_type }}\",\n  \"mitre\": \"{{ $('Parse Result').first().json.mitre }}\",\n  \"triggered_by\": \"auto_escalation\"\n}",
